{
  "expo": {
    "name": "howru-components",
    "slug": "howru-components",
    "version": "1.0.0",
    "scheme": "howru",
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/SF-Pro-Rounded-Bold.otf",
            "./assets/SF-Pro-Rounded-Heavy.otf",
            "./assets/Dotmax.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
